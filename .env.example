# Template only — do NOT put real secrets here.
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local
#
# For Hostinger production: hPanel → Node.js dashboard → Environment Variables

# Resend API key — create at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=info@exceltradeint.com

# Sender address (exceltradeint.com must be verified in Resend)
CONTACT_FROM_EMAIL=ETIL Website <noreply@exceltradeint.com>
